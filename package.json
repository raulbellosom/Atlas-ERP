{
  "name": "atlasrep",
  "private": true,
  "version": "0.0.0",
  "description": "AtlasERP — Plataforma modular de negocio",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "clean:all": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "bootstrap": "bash tools/bootstrap.sh",
    "reset:local": "bash tools/reset-local.sh",
    "db:reset:reseed": "bash tools/reset-db-reseed.sh",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:notes": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "db:migrate": "pnpm --filter=@atlasrep/api db:migrate",
    "db:migrate:prod": "pnpm --filter=@atlasrep/api db:migrate:prod",
    "db:migrate:status": "pnpm --filter=@atlasrep/api db:migrate:status",
    "db:generate": "pnpm --filter=@atlasrep/api db:generate",
    "db:seed": "pnpm --filter=@atlasrep/api db:seed",
    "db:reset": "pnpm --filter=@atlasrep/api db:reset",
    "db:studio": "pnpm --filter=@atlasrep/api db:studio",
    "infra:up": "docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.dev.yml down",
    "infra:reset": "docker compose -f infra/docker/docker-compose.dev.yml down -v",
    "infra:logs": "docker compose -f infra/docker/docker-compose.dev.yml logs -f",
    "infra:status": "docker compose -f infra/docker/docker-compose.dev.yml ps"
  },
  "devDependencies": {
    "@atlasrep/config": "workspace:*",
    "@prisma/client": "^6.7.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "prisma": "^6.7.0",
    "@changesets/cli": "^2.30.0",
    "conventional-changelog-cli": "^5.0.0",
    "turbo": "^2.0.0"
  }
}
