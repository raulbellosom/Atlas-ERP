// ─── HR Core ──────────────────────────────────────────────────────────────────

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  SUSPENDED
}

enum ContractType {
  PERMANENT
  TEMPORARY
  FREELANCE
  INTERNSHIP
}

enum LeaveType {
  VACATION
  SICK
  PERSONAL
  MATERNITY
  PATERNITY
  UNPAID
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Department {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  employees    Employee[]
  positions    Position[]

  @@index([organizationId])
  @@map("departments")
}

model Position {
  id             String    @id @default(cuid())
  organizationId String
  departmentId   String
  name           String
  description    String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  department   Department   @relation(fields: [departmentId], references: [id])
  employees    Employee[]

  @@index([organizationId])
  @@index([departmentId])
  @@map("positions")
}

model Employee {
  id             String           @id @default(cuid())
  organizationId String
  departmentId   String?
  positionId     String?
  employeeCode   String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  curp           String?
  rfc            String?
  birthDate      DateTime?
  hireDate       DateTime
  status         EmploymentStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  organization  Organization       @relation(fields: [organizationId], references: [id])
  department    Department?        @relation(fields: [departmentId], references: [id])
  position      Position?          @relation(fields: [positionId], references: [id])
  contracts     Contract[]
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]
  documents     EmployeeDocument[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
  @@map("employees")
}

model Contract {
  id             String       @id @default(cuid())
  organizationId String
  employeeId     String
  contractType   ContractType
  baseSalary     Decimal      @db.Decimal(14, 2)
  currencyCode   String       @default("MXN")
  startDate      DateTime
  endDate        DateTime?
  isActive       Boolean      @default(true)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([organizationId])
  @@index([employeeId])
  @@map("contracts")
}

model LeaveRequest {
  id             String             @id @default(cuid())
  organizationId String
  employeeId     String
  leaveType      LeaveType
  status         LeaveRequestStatus @default(PENDING)
  startDate      DateTime
  endDate        DateTime
  days           Decimal            @db.Decimal(5, 1)
  reason         String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([organizationId])
  @@index([employeeId])
  @@map("leave_requests")
}

model LeaveBalance {
  id             String    @id @default(cuid())
  organizationId String
  employeeId     String
  leaveType      LeaveType
  year           Int
  totalDays      Decimal   @db.Decimal(5, 1)
  usedDays       Decimal   @default(0) @db.Decimal(5, 1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, leaveType, year])
  @@index([organizationId])
  @@map("leave_balances")
}

model EmployeeDocument {
  id             String    @id @default(cuid())
  organizationId String
  employeeId     String
  documentType   String
  filename       String
  mimeType       String?
  sizeBytes      Int?
  uploadedById   String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([organizationId])
  @@index([employeeId])
  @@map("employee_documents")
}

// ─── Module Store ─────────────────────────────────────────────────────────────

enum ModuleLifecycleState {
  ACTIVE
  DEPRECATED
  DISABLED
}

enum ModuleInstallStatus {
  INSTALLED
  DISABLED
  UPGRADING
  ERROR
}

enum ModuleJobOperation {
  INSTALL
  UNINSTALL
  UPGRADE
}

enum ModuleJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  ROLLED_BACK
}

model ModuleDefinition {
  moduleKey      String               @id
  name           String
  description    String?
  isCore         Boolean              @default(false)
  ownerModule    String?
  lifecycleState ModuleLifecycleState @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  versions      ModuleVersion[]
  dependencies  ModuleDependency[]          @relation("SourceModule")
  dependents    ModuleDependency[]          @relation("DependsOnModule")
  installations TenantModuleInstallation[]
  jobs          ModuleInstallJob[]
  auditEvents   ModuleLifecycleAuditEvent[]

  @@map("module_definitions")
}

model ModuleVersion {
  id                 String   @id @default(cuid())
  moduleKey          String
  version            String
  compatibilityRange String
  manifestChecksum   String
  publishedAt        DateTime @default(now())

  module ModuleDefinition @relation(fields: [moduleKey], references: [moduleKey], onDelete: Cascade)

  @@unique([moduleKey, version])
  @@map("module_versions")
}

model ModuleDependency {
  id                 String  @id @default(cuid())
  moduleKey          String
  dependsOnModuleKey String
  versionConstraint  String
  isHardDependency   Boolean @default(true)

  module    ModuleDefinition @relation("SourceModule", fields: [moduleKey], references: [moduleKey], onDelete: Cascade)
  dependsOn ModuleDefinition @relation("DependsOnModule", fields: [dependsOnModuleKey], references: [moduleKey], onDelete: Restrict)

  @@unique([moduleKey, dependsOnModuleKey])
  @@map("module_dependencies")
}

model TenantModuleInstallation {
  id             String              @id @default(cuid())
  organizationId String
  moduleKey      String
  version        String
  status         ModuleInstallStatus @default(INSTALLED)
  installedAt    DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lastJobId      String?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  module       ModuleDefinition @relation(fields: [moduleKey], references: [moduleKey], onDelete: Restrict)

  @@unique([organizationId, moduleKey])
  @@map("tenant_module_installations")
}

model ModuleInstallJob {
  id             String             @id @default(cuid())
  organizationId String
  moduleKey      String
  operation      ModuleJobOperation
  status         ModuleJobStatus    @default(PENDING)
  requestId      String             @unique
  traceId        String?
  logJson        Json?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  module       ModuleDefinition @relation(fields: [moduleKey], references: [moduleKey], onDelete: Restrict)

  @@index([organizationId, status])
  @@index([requestId])
  @@map("module_install_jobs")
}

model ModuleLifecycleAuditEvent {
  id             String   @id @default(cuid())
  organizationId String
  moduleKey      String
  action         String
  actorUserId    String
  beforeState    Json?
  afterState     Json?
  createdAt      DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  module       ModuleDefinition @relation(fields: [moduleKey], references: [moduleKey], onDelete: Restrict)

  @@index([organizationId, moduleKey])
  @@map("module_lifecycle_audit_events")
}
