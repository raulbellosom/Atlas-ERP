root = true

# Regla general para todos los archivos
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown: no eliminar espacios al final (se usan para line breaks)
[*.md]
trim_trailing_whitespace = false
max_line_length = 80

# YAML
[*.{yaml,yml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# Archivos de Rust (Tauri) — mantener configuracion de rustfmt
[*.rs]
indent_style = space
indent_size = 4

# Makefiles requieren tabs
[Makefile]
indent_style = tab
