# AtlasERP - Variables de entorno canonicas
#
# Copia este archivo a .env en la raiz del repositorio:
#   cp .env.example .env
#
# Este es el unico .env.example soportado para desarrollo local.
# No crear .env por app. API, worker, web y desktop leen este archivo raiz.
# Nunca commitear .env con valores reales.

# Infraestructura local compartida
POSTGRES_USER=atlaserp
POSTGRES_PASSWORD=atlaserp_dev
POSTGRES_DB=atlaserp_dev
DATABASE_URL="postgresql://atlaserp:atlaserp_dev@localhost:5432/atlaserp_dev"

REDIS_HOST=localhost
REDIS_PORT=6379
# Solo requerido si Redis exige autenticacion (normalmente prod).
REDIS_PASSWORD=

# Almacenamiento de archivos S3-compatible.
# En desarrollo local el proveedor es MinIO; en prod puede ser MinIO, AWS S3
# u otro servicio compatible con el API de S3.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=atlaserp
S3_SECRET_KEY=atlaserp_dev
S3_BUCKET=atlaserp-dev
S3_REGION=us-east-1
S3_PRESIGNED_EXPIRY_SECONDS=300

# API NestJS
NODE_ENV=development
PORT=3000
API_PREFIX=api
WEB_APP_URL=http://localhost:5173
JWT_SECRET=change-me-in-production-use-32-chars-min
JWT_EXPIRES_IN=7d
LOG_LEVEL=info

# Web y Desktop (Vite). Todo VITE_* queda expuesto al bundle del cliente.
VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME=AtlasERP
VITE_ENV=development
VITE_DESKTOP_DATA_DIR=

# Desktop nativo (Tauri)
DESKTOP_DATA_DIR=

# Module Store remoto (opcional; por defecto se usa catalogo curado local).
MODULE_STORE_PROVIDER=curated
MODULE_STORE_REMOTE_CATALOG_URL=
MODULE_STORE_REMOTE_TRUSTED_SIGNERS=
MODULE_STORE_REMOTE_CANARY_ORGS=
MODULE_STORE_REMOTE_PARTIAL_PERCENT=
MODULE_STORE_REMOTE_ROLLOUT_STAGE=

# Docker staging/prod (solo cuando se usan los compose de esos ambientes).
IMAGE_TAG=latest
