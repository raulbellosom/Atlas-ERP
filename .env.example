# AtlasERP — Variables de entorno raiz
# Este archivo documenta las variables globales del monorepo.
# Cada app tiene su propio .env.example con variables especificas.
#
# NUNCA commitear archivos .env — estan en .gitignore.
# Ver: docs/02-architecture/10-estrategia-environment-variables.md
# Ver: docs/02-architecture/18-referencia-env-vars.md
#
# ─── Variables de infraestructura compartida ──────────────────────────────────
# Usadas por api, worker y seeds. Coinciden con docker-compose.dev.yml.

DATABASE_URL="postgresql://atlaserp:atlaserp_dev@localhost:5432/atlaserp_dev"

REDIS_HOST=localhost
REDIS_PORT=6379

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=atlaserp
S3_SECRET_KEY=atlaserp_dev
S3_BUCKET=atlaserp-dev
S3_REGION=us-east-1

# ─── Variables por app ────────────────────────────────────────────────────────
# Ver los .env.example de cada app para su lista completa:
#   apps/api/.env.example
#   apps/web/.env.example     (por crear en T-0330)
#   apps/worker/.env.example  (por crear en T-0330)
#   apps/desktop/.env.example (por crear en T-0330)


