# AtlasERP Worker — Variables de entorno (NestJS + BullMQ)
# Copiar a .env y completar:
#   cp apps/worker/.env.example apps/worker/.env
#
# NUNCA commitear el archivo .env — está en .gitignore

# Base de datos (PostgreSQL)
DATABASE_URL="postgresql://atlaserp:atlaserp_dev@localhost:5432/atlaserp_dev"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Almacenamiento (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=atlaserp
S3_SECRET_KEY=atlaserp_dev
S3_BUCKET=atlaserp-dev
S3_REGION=us-east-1

# Worker
NODE_ENV=development

# Logging
# Niveles: trace | debug | info | warn | error
LOG_LEVEL=info