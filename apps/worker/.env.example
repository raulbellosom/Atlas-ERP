# AtlasERP Worker — Variables de entorno (NestJS + BullMQ)
# Copiar a .env y completar:
#   cp apps/worker/.env.example apps/worker/.env
#
# NUNCA commitear el archivo .env — esta en .gitignore

# ─── Base de datos (PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL="postgresql://atlasrep:atlasrep_dev@localhost:5432/atlasrep_dev"

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Almacenamiento (MinIO / S3) ──────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=atlasrep
S3_SECRET_KEY=atlasrep_dev
S3_BUCKET=atlasrep-dev
S3_REGION=us-east-1

# ─── Worker ───────────────────────────────────────────────────────────────────
NODE_ENV=development
