    "@tailwindcss/vite": "^4.1.3",
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "tailwindcss": "^4.1.3",
    "vite": "^6.0.5"
  }
