{
  "name": "@atlasrep/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "App desktop - Tauri + React + SQLite local",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite --port 5174 --strictPort",
