{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AtlasERP Desktop",
  "version": "0.0.0",
  "identifier": "com.racoondevs.atlaserp.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter=@atlasrep/desktop dev:web",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "pnpm --filter=@atlasrep/desktop build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AtlasERP Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
