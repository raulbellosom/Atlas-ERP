# AtlasERP Desktop â€” Variables de entorno (Tauri + Vite)
# Las variables VITE_* son accesibles en el frontend embebido.
# La configuracion nativa del desktop se gestiona en SQLite local via Tauri.
#
# Copiar a .env:
#   cp apps/desktop/.env.example apps/desktop/.env

# â”€â”€â”€ API backend â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
VITE_API_URL=http://localhost:3000/api

# â”€â”€â”€ App â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
VITE_APP_NAME=AtlasERP
VITE_ENV=development

# â”€â”€â”€ Desktop (Tauri nativo) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Directorio de datos local. Si esta vacio, Tauri usa el directorio por defecto
# del sistema operativo (~/.atlaserp o %APPDATA%\atlaserp en Windows).
DESKTOP_DATA_DIR=

# Variante expuesta al frontend (React/Vite) cuando se requiere mostrar/leer
# el valor dentro de la UI.
VITE_DESKTOP_DATA_DIR=

