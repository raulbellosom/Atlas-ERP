# AtlasERP Web — Variables de entorno (Vite)
# Solo las variables con prefijo VITE_ son accesibles en el navegador.
# Copiar a .env y completar:
#   cp apps/web/.env.example apps/web/.env
#
# NUNCA commitear el archivo .env — esta en .gitignore

# ─── API ──────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=AtlasERP
VITE_ENV=development

# ─── Organización por defecto (dev single-tenant) ─────────────────────────────
# Obtener con: node -e "..." o desde el seed output
VITE_DEFAULT_ORG_ID=
