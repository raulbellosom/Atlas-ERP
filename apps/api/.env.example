# AtlasERP API — Variables de entorno
# Copiar a .env y completar con valores locales:
#   cp apps/api/.env.example apps/api/.env
#
# NUNCA commitear el archivo .env — esta en .gitignore

# ─── Base de datos (PostgreSQL) ───────────────────────────────────────────────
DATABASE_URL="postgresql://atlaserp:atlaserp_dev@localhost:5432/atlaserp_dev"

# ─── Redis (BullMQ / Worker) ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Almacenamiento de archivos (MinIO / S3-compatible) ───────────────────────
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=atlaserp
S3_SECRET_KEY=atlaserp_dev
S3_BUCKET=atlaserp-dev
S3_REGION=us-east-1
S3_PRESIGNED_EXPIRY_SECONDS=300

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-32-chars-min
JWT_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Logging ──────────────────────────────────────────────────────────────────
# Niveles: trace | debug | info | warn | error
LOG_LEVEL=info


