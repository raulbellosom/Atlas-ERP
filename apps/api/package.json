{
  "name": "@atlasrep/api",
  "version": "0.0.0",
  "private": true,
  "description": "Backend central - NestJS + Prisma + PostgreSQL",
  "scripts": {
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --passWithNoTests",
    "test:sync-core": "tsx --test src/modules/sync/*.test.ts",
    "test:finops-integration": "tsx --test src/modules/financial-movements/finops-integration.test.ts",
    "test:finops-permissions": "tsx --test src/modules/financial-movements/finops-permissions.test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema ../../prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema ../../prisma/schema.prisma",
    "db:migrate:create": "prisma migrate dev --create-only --schema ../../prisma/schema.prisma",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "db:seed": "prisma db seed --schema ../../prisma/schema.prisma",
    "db:reset": "prisma migrate reset --force --schema ../../prisma/schema.prisma",
    "db:studio": "prisma studio --schema ../../prisma/schema.prisma"
  },
  "prisma": {
    "seed": "tsx ../../prisma/seeds/index.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.8",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "minio": "^8.0.6",
    "multer": "^2.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@atlasrep/config": "workspace:*",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.6",
    "@nestjs/testing": "^11.1.8",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.18.1",
    "prisma": "^6.7.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
