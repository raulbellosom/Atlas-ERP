{
  "name": "@atlaserp/api",
  "version": "0.0.0",
  "private": true,
  "description": "Backend central - NestJS + Prisma + PostgreSQL",
  "scripts": {
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --config jest.config.unit.js --passWithNoTests",
    "test:unit:coverage": "jest --config jest.config.unit.js --coverage --passWithNoTests",
    "test:integration": "jest --config jest.config.integration.js --runInBand --passWithNoTests --forceExit",
    "test:e2e": "jest --config jest.config.e2e.js --runInBand --passWithNoTests --forceExit",
    "test:sync-core": "tsx --test src/modules/sync/*.test.ts",
    "test:finops-integration": "tsx --test src/modules/financial-movements/finops-integration.test.ts",
    "test:finops-permissions": "tsx --test src/modules/financial-movements/finops-permissions.test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:migrate": "node ../../tools/run-prisma-with-root-env.mjs migrate dev --schema ../../prisma/schema.prisma",
    "db:migrate:prod": "node ../../tools/run-prisma-with-root-env.mjs migrate deploy --schema ../../prisma/schema.prisma",
    "db:migrate:status": "node ../../tools/run-prisma-with-root-env.mjs migrate status --schema ../../prisma/schema.prisma",
    "db:migrate:create": "node ../../tools/run-prisma-with-root-env.mjs migrate dev --create-only --schema ../../prisma/schema.prisma",
    "db:generate": "node ../../tools/run-prisma-with-root-env.mjs generate --schema ../../prisma/schema.prisma",
    "db:seed": "node ../../tools/run-prisma-with-root-env.mjs db seed --schema ../../prisma/schema.prisma",
    "seed:setup": "node ../../tools/run-with-root-env.mjs tsx ../../prisma/seeds/setup-bootstrap.ts",
    "db:reset": "node ../../tools/run-prisma-with-root-env.mjs migrate reset --force --skip-seed --schema ../../prisma/schema.prisma",
    "db:studio": "node ../../tools/run-prisma-with-root-env.mjs studio --schema ../../prisma/schema.prisma"
  },
  "prisma": {
    "seed": "tsx ../../prisma/seeds/index.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.6.1",
    "minio": "^8.0.6",
    "multer": "^2.0.2",
    "nestjs-pino": "^4.4.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@atlaserp/config": "workspace:*",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.6",
    "@nestjs/testing": "^11.1.8",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.18.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "jsonwebtoken": "^9.0.3",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
